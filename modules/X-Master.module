#!name=рҹҡҖ X-Master Premium
#!desc=рҹ‘‘ [v3.5] Ultimate System Core by Xwuan. All-In-One: Multimedia (YT/Music/Spotify), Graphic & Social Services.
#!author=рҹ‘Ө Xwuan

[General]
user-agent = Locket/1.0.0 (iPhone; iOS 26; Scale/3.00)

[Rule]
# Chбә·n UDP Д‘б»ғ Г©p luб»“ng Multimedia chбәЎy qua script tб»‘i Ж°u cб»§a Xwuan[cite: 4]
AND,((DOMAIN-SUFFIX,googlevideo.com), (PROTOCOL,UDP)),REJECT[cite: 4]
AND,((DOMAIN,youtubei.googleapis.com), (PROTOCOL,UDP)),REJECT[cite: 4]

[Script]
# --- рҹӣЎпёҸ INTERNAL CORE (Locket, RedMode, Picsart...) ---
# бәЁn danh cГЎc dб»Ӣch vб»Ҙ xГЎc thб»ұc Д‘б»ғ trГЎnh bб»Ӣ soi code
v1_core = type=http-response, pattern=^https:\/\/api\.v1\.cloud\/.*\/(auth$|verify\/[^/]+$), script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Locket/locketXn.js, requires-body=true, max-size=-1, timeout=120[cite: 3]
v1_header = type=http-request, pattern=^https:\/\/api\.v1\.cloud\/.*\/(auth|verify), script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Locket/deleteHeader.js, timeout=120[cite: 3]

# --- рҹҺө MULTIMEDIA (Spotify, YouTube, YT Music) ---
# Spotify Optimization[cite: 3]
m_proto = type=http-response, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Spotify/spotify-proto.js, requires-body=1, binary-body-mode=1, timeout=10[cite: 3]

# YouTube & YouTube Music (Sб»ӯ dб»Ҙng cбәҘu trГәc hoбәЎt Д‘б»ҷng tб»‘t nhбәҘt cб»§a Xwuan)
# Thay thбәҝ script-path sang link JS bбәЎn vб»«a lГ m thГ nh cГҙng
m_stream = type=http-response, pattern=^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$, requires-body=1, max-size=-1, binary-body-mode=1, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Youtube/yt.js, argument="{"lyricLang":"vi","captionLang":"vi","blockUpload":true,"blockImmersive":true,"blockShorts":false,"debug":false}"[cite: 1, 4]

# --- рҹҺЁ GRAPHIC (Picsart) ---
g_auth = type=http-request, pattern=https://api.picsart.com/gw-v2/shop/subscription/apple/purchases, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Picsart/PicsArt.js, requires-body=true, timeout=5[cite: 3]

[Map Local]
# Chбә·n Д‘б»©ng request quбәЈng cГЎo mб»“i trГӘn luб»“ng video/music[cite: 4]
^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad data-type=text data="" status-code=200[cite: 4]

[MITM]
# Gб»ҷp toГ n bб»ҷ hostname vГ  Д‘Ж°a domain quan trб»Қng lГӘn Д‘бә§u[cite: 3, 4]
hostname = %APPEND% youtubei.googleapis.com, *.googlevideo.com, api.*.com, *.spotify.com, spclient.wg.spotify.com, api.picsart.com, raw.githubusercontent.com[cite: 3, 4]
