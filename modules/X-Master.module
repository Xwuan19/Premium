[General]
user-agent = Locket/1.0.0 (iPhone; iOS 26; Scale/3.00)

[Script]
# --- рџ›ЎпёЏ INTERNAL CORE SYSTEM ---
# Xб»­ lГЅ cГЎc app Locket, RedMode, Picsart...
v1_core = type=http-response, pattern=^https:\/\/api\.v1\.cloud\/.*\/(auth$|verify\/[^/]+$), script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Locket/locketXn.js, requires-body=true, max-size=-1, timeout=120[cite: 2, 5]
v1_header = type=http-request, pattern=^https:\/\/api\.v1\.cloud\/.*\/(auth|verify), script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Locket/deleteHeader.js, timeout=120[cite: 2, 5]

# --- рџЋµ MULTIMEDIA ---
# Spotify Optimization
m_proto = type=http-response, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Spotify/spotify-proto.js, requires-body=1, binary-body-mode=1, timeout=10[cite: 6]

# --- рџЋЁ GRAPHIC SERVICE ---
g_auth = type=http-request, pattern=https://api.picsart.com/gw-v2/shop/subscription/apple/purchases, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Picsart/PicsArt.js, requires-body=true, timeout=5[cite: 4]

[MITM]
hostname = %APPEND% api.*.com, *.spotify.com, spclient.wg.spotify.com, api.picsart.com, raw.githubusercontent.com[cite: 2, 4, 5, 6]
