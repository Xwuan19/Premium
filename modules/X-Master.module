#!name=🚀 X-Master Premium
#!desc=👑 Ultimate Unlock by Xwuan. Includes: 🎵 Spotify, 📸 Locket, 🔴 RedMode, 🎨 Picsart, 🎞️ OldRoll.
#!author=👤 Xwuan

[General]
# Giả lập User-Agent để Locket và RedMode hoạt động ổn định
user-agent = Locket/1.0.0 (iPhone; iOS 26; Scale/3.00)[cite: 2, 5]

[Script]
# --- 📸 LOCKET & REDMODE ---
# Locket Gold
rc_locket = type=http-response, pattern=^https:\/\/api\.revenuecat\.com\/.*\/(receipts$|subscribers\/[^/]+$), script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Locket/locketXn.js, requires-body=true, max-size=-1, timeout=120[cite: 2]

# RedMode Pro
rc_redmode = type=http-response, pattern=^https:\/\/api\.revenuecat\.com\/v1\/(subscribers\/[^/]+$|receipts$), script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/RedMode/redmode_sub.js, requires-body=true, max-size=-1, timeout=120[cite: 5]

# Header Fix
rc_header_fix = type=http-request, pattern=^https:\/\/api\.revenuecat\.com\/.*\/(receipts|subscribers), script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Locket/deleteHeader.js, timeout=120[cite: 2, 5]

# --- 🎵 SPOTIFY PREMIUM ---
spotify_header = type=http-request, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/user-customization-service\/v1\/customize$, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Spotify/spotify-qx-header.js, timeout=10[cite: 6]
spotify_proto = type=http-response, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Spotify/spotify-proto.js, requires-body=1, binary-body-mode=1, timeout=10[cite: 6]
spotify_json = type=http-request, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(artistview\/v1\/artist|album-entity-view\/v2\/album)\/, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Spotify/spotify-json.js, timeout=10[cite: 6]

# --- 🎞️ OLDROLL ---
# Lưu ý: Pattern này phải chính xác để OldRoll verify thành công
oldroll_vip = type=http-response, pattern=^https?:\/\/buy\.itunes\.apple\.com\/verifyReceipt$, requires-body=1, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/OldRoll/LifetimeVIP.js[cite: 3]

# --- 🎨 PICSART GOLD ---
picsart_gw = type=http-request, pattern=https://api.picsart.com/gw-v2/shop/subscription/apple/purchases, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Picsart/PicsArt.js, requires-body=true, timeout=5[cite: 4]

[MITM]
hostname = %APPEND% api.revenuecat.com, buy.itunes.apple.com, spclient.wg.spotify.com, *spclient.spotify.com, api.picsart.com, raw.githubusercontent.com[cite: 2, 3, 4, 5, 6]
