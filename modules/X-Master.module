#!name=🚀 X-Master Premium
#!desc=🌟 Ultimate System Core by Xwuan.
#!author=👤 Xwuan

[General]
user-agent = Locket/1.0.0 (iPhone; iOS 26; Scale/3.00)[cite: 3]

[Rule]
# Chặn UDP để ép toàn bộ luồng Multimedia đi qua script xử lý của Xwuan
AND,((DOMAIN-SUFFIX,googlevideo.com), (PROTOCOL,UDP)),REJECT[cite: 2]
AND,((DOMAIN,youtubei.googleapis.com), (PROTOCOL,UDP)),REJECT[cite: 2]

[Script]
# --- 🛡️ INTERNAL CORE SYSTEM (Locket, RedMode, Picsart...) ---
v1_core = type=http-response, pattern=^https:\/\/api\.v1\.cloud\/.*\/(auth$|verify\/[^/]+$), script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Locket/locketXn.js, requires-body=true, max-size=-1, timeout=120[cite: 3]
v1_header = type=http-request, pattern=^https:\/\/api\.v1\.cloud\/.*\/(auth|verify), script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Locket/deleteHeader.js, timeout=120[cite: 3]

# --- 🎵 MULTIMEDIA SERVICE (Spotify, YouTube, YT Music) ---
# Xử lý Spotify[cite: 3]
m_proto = type=http-response, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Spotify/spotify-proto.js, requires-body=1, binary-body-mode=1, timeout=10[cite: 3]

# Xử lý YouTube & YouTube Music
m_stream = type=http-response, pattern=^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$, requires-body=1, max-size=-1, binary-body-mode=1, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Youtube/yt.js, argument="{"lyricLang":"vi","captionLang":"vi","blockUpload":true,"blockImmersive":true,"blockShorts":false,"debug":false}"[cite: 1, 2]

# --- 🎨 GRAPHIC SERVICE (Picsart) ---
g_auth = type=http-request, pattern=https://api.picsart.com/gw-v2/shop/subscription/apple/purchases, script-path=https://raw.githubusercontent.com/Xwuan19/Premium/refs/heads/main/js/Picsart/PicsArt.js, requires-body=true, timeout=5[cite: 3]

[Map Local]
^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad data-type=text data="" status-code=200[cite: 2]

[MITM]
hostname = %APPEND% api.*.com, *.spotify.com, spclient.wg.spotify.com, youtubei.googleapis.com, *.googlevideo.com, api.picsart.com, raw.githubusercontent.com[cite: 1, 2, 3]
